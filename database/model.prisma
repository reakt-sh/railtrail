datasource db {
    provider = "postgresql"
    url      = env("DB_URL")
}

// Position Tracking Models

model Vehicle {
    uid         Int @id @default(autoincrement())

    info        Json // Must satisfy VehicleInfo json schema

    // Implicit relations
    tracker     Tracker[]
    rawData     RawData[]
    analyses    Analysis[]
    feedback    Feedback[]
}

model Tracker {
    uid         Int @id @default(autoincrement())

    info        Json // Must satisfy TrackerInfo json schema

    vehicleId   Int?
    vehicle     Vehicle? @relation(fields: [vehicleId], references: [uid])

    // Implicit relations
    rawData     RawData[]
}

model RawData {
    uid         Int @id @default(autoincrement())

    trackerId   Int
    tracker     Tracker @relation(fields: [trackerId], references: [uid])

    vehicleId   Int?
    vehicle     Vehicle? @relation(fields: [vehicleId], references: [uid])

    timestamp   DateTime
    processed   DateTime
    data        Json // Must satisfy Position json schema

    // Implicit relations
    analyses    AnalysisSource[]

    @@index([timestamp(sort: Desc)])
}

model Analysis {
    uid         Int @id @default(autoincrement())

    vehicleId   Int?
    vehicle     Vehicle? @relation(fields: [vehicleId], references: [uid])

    timestamp   DateTime
    obsolete    Boolean @default(false)
    data        Json // Must satisfy AnalysisInfo json schema

    // Implicit relations
    sources     AnalysisSource[]

    @@index([timestamp(sort: Desc)])
}

model AnalysisSource {
    @@id([analysisId, dataId])

    analysisId  Int
    analysis    Analysis @relation(fields: [analysisId], references: [uid])

    dataId      Int
    data        RawData @relation(fields: [dataId], references: [uid])
}

// Additional data models

model Feedback {
    uid         Int @id @default(autoincrement())

    timestamp   DateTime
    data        Json // Must satisfy Feedback json schema

    vehicleId   Int?
    vehicle     Vehicle? @relation(fields: [vehicleId], references: [uid])
}

// Website

model Session {
    id          String   @id
    sid         String   @unique
    data        String
    expiresAt   DateTime
}
